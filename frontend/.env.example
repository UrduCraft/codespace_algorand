# Silexa Frontend Environment Configuration

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_WS_BASE_URL=ws://localhost:8000

# Algorand Configuration
REACT_APP_ALGOD_SERVER=https://testnet-api.algonode.cloud
REACT_APP_ALGOD_PORT=443
REACT_APP_INDEXER_SERVER=https://testnet-idx.algonode.cloud
REACT_APP_INDEXER_PORT=443

# App Configuration
REACT_APP_APP_NAME=Silexa
REACT_APP_VERSION=1.0.0

# Feature Flags
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_FILE_SHARING=true

# Development
REACT_APP_DEBUG=true